{
  "name": "onoff-ecommerce",
  "version": "2.0.0",
  "description": "Fashion e-commerce platform built with Next.js 15, TypeScript, Tailwind CSS 4, Prisma ORM",
  "author": "Nguyễn Sơn",
  "license": "MIT",
  "homepage": "https://onoff.vn",
  "repository": {
    "type": "git",
    "url": "https://github.com/JasonTM17/ON-OFF_JS.git"
  },
  "keywords": ["ecommerce", "nextjs", "typescript", "tailwindcss", "prisma", "fashion"],
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma db push --force-reset && tsx prisma/seed.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
