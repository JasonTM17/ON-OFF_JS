{
  "name": "ONFIT AI Chatbot",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "chat",
        "responseMode": "responseNode"
      },
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "position": [250, 300]
    },
    {
      "parameters": {
        "model": "claude-sonnet-4-20250514",
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "Ban la tro ly ao cua ONFIT - thuong hieu do lot va do mac nha cao cap Viet Nam. Tra loi ngan gon, than thien, bang tieng Viet. Ban co the: tu van size, goi y san pham, giai dap chinh sach giao hang/doi tra/thanh toan, tra cuu don hang. Luon kem quickReplies (mang 2-4 goi y). Tra ve JSON: {reply, quickReplies}."
            },
            {
              "role": "user",
              "content": "={{$json.body.message}}"
            }
          ]
        }
      },
      "name": "AI Chat",
      "type": "n8n-nodes-base.openAi",
      "position": [500, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{JSON.parse($json.message.content)}}"
      },
      "name": "Respond",
      "type": "n8n-nodes-base.respondToWebhook",
      "position": [750, 300]
    }
  ],
  "connections": {
    "Webhook": { "main": [[{ "node": "AI Chat", "type": "main", "index": 0 }]] },
    "AI Chat": { "main": [[{ "node": "Respond", "type": "main", "index": 0 }]] }
  }
}
