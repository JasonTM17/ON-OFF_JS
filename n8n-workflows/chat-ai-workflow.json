{
  "name": "ONFIT AI Chatbot",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "chat",
        "responseMode": "responseNode"
      },
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "position": [250, 300]
    },
    {
      "parameters": {
        "model": "gpt-4o",
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "Bạn là trợ lý ảo của ONFIT - thương hiệu đồ lót và đồ mặc nhà cao cấp Việt Nam. Trả lời ngắn gọn, thân thiện, bằng tiếng Việt. Bạn có thể: tư vấn size, gợi ý sản phẩm, giải đáp chính sách giao hàng/đổi trả/thanh toán, tra cứu đơn hàng. Luôn kèm quickReplies (mảng 2-4 gợi ý). Trả về JSON: {reply, quickReplies}."
            },
            {
              "role": "user",
              "content": "={{$json.body.message}}"
            }
          ]
        }
      },
      "name": "AI Chat",
      "type": "n8n-nodes-base.openAi",
      "position": [500, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{JSON.parse($json.message.content)}}"
      },
      "name": "Respond",
      "type": "n8n-nodes-base.respondToWebhook",
      "position": [750, 300]
    }
  ],
  "connections": {
    "Webhook": { "main": [[{ "node": "AI Chat", "type": "main", "index": 0 }]] },
    "AI Chat": { "main": [[{ "node": "Respond", "type": "main", "index": 0 }]] }
  }
}
